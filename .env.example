# DroneDetect configuration
# Copy to .env and fill in values before use

DRONEDETECT_DATA_DIR=./data/raw
DRONEDETECT_FEATURES_DIR=./data/features
DRONEDETECT_MODELS_DIR=./data/models
DRONEDETECT_METADATA_CACHE=./data/metadata_cache.parquet

S3_ENDPOINT_URL=https://s3.fr-par.scw.cloud
S3_REGION=fr-par
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
S3_BUCKET=mlops-data
S3_RAW_PREFIX=raw/
S3_FEATURES_PREFIX=mldrone/features/
