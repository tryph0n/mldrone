digraph PipelineGlobal {
    rankdir=LR;
    node [shape=box, style="rounded,filled", fontname="Arial", fontsize=11];
    edge [fontname="Arial", fontsize=10];

    // Input
    raw [label="Raw .dat file\n(S3 / Scaleway)", fillcolor="#FFE6E6"];

    // Loading
    load [label="load_raw_iq()\n120M complex64 samples", fillcolor="#FFF4E6"];

    // Segmentation
    seg [label="Segmentation\n100 x 20ms\n(1.2M samples each)", fillcolor="#E6F3FF"];

    // Branch-specific normalization + feature extraction
    subgraph cluster_psd {
        label="PSD Branch";
        style=dashed;
        color="#CC6680";
        norm_psd [label="Z-score\nnormalization", fillcolor="#FFE6F0"];
        psd [label="Welch PSD\nnperseg=1024, hamming\nnoverlap=512, fftshift\nmax normalization\n(1024,)", fillcolor="#FFE6F0"];
    }

    subgraph cluster_spectro {
        label="Spectrogram Branch";
        style=dashed;
        color="#8066CC";
        norm_spec [label="Z-score\nnormalization", fillcolor="#F0E6FF"];
        spec [label="STFT\nnperseg=1024, hann\nnoverlap=120, fftshift\nresize 224x224\ndB + min-max [0,1]\nViridis RGB\n(224,224,3)", fillcolor="#F0E6FF"];
    }

    subgraph cluster_iq {
        label="IQ Raw Branch";
        style=dashed;
        color="#999933";
        norm_iq [label="Min-max [0,1]\nper I/Q channel", fillcolor="#FFFFE6"];
        iq [label="np.interp downsample\n1.2M -> 10K (120x)\n(2,10000)", fillcolor="#FFFFE6"];
    }

    // Models
    subgraph cluster_models {
        label="Classification Models";
        style=dashed;
        color="#339966";
        svm [label="SVM\nRBF kernel", fillcolor="#D4EDDA"];
        vgg [label="VGG16\nTransfer Learning", fillcolor="#D4EDDA"];
        resnet [label="ResNet50\nTransfer Learning", fillcolor="#D4EDDA"];
        rfuav [label="RF-UAVNet\n1D CNN", fillcolor="#D4EDDA"];
    }

    // Output
    pred [label="Drone Class\n(7 classes)", fillcolor="#D1ECF1"];

    // Edges — main pipeline
    raw -> load;
    load -> seg;

    // Branching from segmentation into 3 parallel paths
    seg -> norm_psd;
    seg -> norm_spec;
    seg -> norm_iq;

    // Each branch: normalize then extract features
    norm_psd -> psd;
    norm_spec -> spec;
    norm_iq -> iq;

    // Features to models
    psd -> svm;
    spec -> vgg;
    spec -> resnet;
    iq -> rfuav;

    // Models to prediction
    svm -> pred;
    vgg -> pred;
    resnet -> pred;
    rfuav -> pred;
}
